# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env no git

# String de conexão com o banco PostgreSQL
DATABASE_URL=postgres://usuario:senha@host:porta/banco

# Desabilita SSL do banco apenas em desenvolvimento local (remova em produção)
# DATABASE_SSL=false

# Segredo para assinar os tokens JWT (use uma string longa e aleatória)
JWT_SECRET=troque-por-uma-string-aleatoria-longa-e-segura

# Tempo de expiração do token JWT (ex: 7d, 24h, 1h)
JWT_EXPIRES_IN=7d

# Origens permitidas no CORS (separadas por vírgula)
ALLOWED_ORIGINS=https://seu-dominio.vercel.app,http://localhost:5500

# Porta do servidor (opcional, padrão: 3000)
PORT=3000
